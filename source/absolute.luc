// returns the modulus of the input

module absolute (
    signed input in[32],
    output abs[32]
) { 
    always {
        if (in[31]) {          // If the sign bit is 1 (negative number)
            // ~in flips all 32 bits simultaneously.
            // + 1 completes the Two's Complement negation.
            abs = ~in + 1b1   
        } 
        else {                 // If positive
           abs = in
        }
    }
}