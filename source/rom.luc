module rom (
    input addr[6],
    output timestamp[32]
) {
    const ROM = $reverse({
        32d4001, // 0
        32d5001, // 1
        32d6001, // 2
        32d7001, // 3
        
        32d20001, // 4
        32d21001, // 5
        32d21501, // 6
        32d22001, // 7
        32d23001, // 8
        
        32d36001, // 9
        32d36501, // 10
        32d37001, // 11
        32d38001, // 12
        32d39001, // 13
        
        32d52001, // 14
        32d53501, // 15
        32d54501, // 16
        32d55001, // 17
        
        32d68001, // 18
        32d68501, // 19
        32d68701, // 20
        32d69001, // 21
        32d69501, // 22
        32d70501, // 23
        32d71001, // 24

        32d12000, // 25
        32d13001, // 26
        32d14001, // 27
        32d15001, // 28
        
        32d28001, // 29
        32d29001, // 30
        32d29501, // 31
        32d30001, // 32
        32d31001, // 33
        
        32d44001, // 34
        32d44501, // 35
        32d45001, // 36
        32d46001, // 37
        32d47001, // 38
        
        32d60001, // 39
        32d61501, // 40
        32d62501, // 41
        32d63001, // 42
        
        32d76001, // 43
        32d76501, // 44
        32d76701, // 45
        32d77001, // 46
        32d77501, // 47
        32d78501, // 48
        32d79001,  // 49
        32d90000,
        32d90000,
        32d90000,
            
            // PADDING TO 64 ELEMENTS TO PREVENT SIMULATOR CRASHES!
        32d90000, 32d90000, 32d90000, 32d90000, 32d90000, // 53 - 57
        32d90000, 32d90000, 32d90000, 32d90000, 32d90000, // 58 - 62
        32d90000                          // 63
    })
    
    always {
        timestamp = ROM[addr <= 49 ? addr : 50]
        //added ROM ts check so that it doenst read if index out of bounds
    }
}