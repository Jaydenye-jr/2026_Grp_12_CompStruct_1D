    pin seg_units[2]    A39   // c
    pin seg_units[3]    A36   // d
    pin seg_units[4]    A33   // e
    pin seg_units[5]    A27   // f
    pin seg_units[6]    A30   // g

    // Row 2: A28 A31 A34 A37 A40 A43 A46 A49
    pin seg_tens[0]     A43   // a (was f)
    pin seg_tens[1]     A46   // b 
    pin seg_tens[2]     A40   // c 
    pin seg_tens[3]     A37   // d 
    pin seg_tens[4]     A34   // e 
    pin seg_tens[5]     A28   // f (was a)
