    // ── Metronome LEDs ──────────────────────────
    pin led_metro[0]        B39
    pin led_metro[1]        B43
    pin led_metro[2]        B45
    pin led_metro[3]        B46

    // ── Note Display LED ────────────────────────
    pin led_note            B48

    // ── Feedback LEDs ───────────────────────────
    pin led_red             B49
    pin led_yellow          B2
    pin led_green           B3

    // ── Buzzer ──────────────────────────────────
    pin buzzer_pin          B5
    
    // ── Push Button ──────────────────────────────────
    pin big_PUSH_button    B6
    
    // ── 7-Segment: Units ────────────────────────
